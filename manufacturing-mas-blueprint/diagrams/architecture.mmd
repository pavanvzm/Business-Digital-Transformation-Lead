%% Manufacturing MAS Architecture Diagram
%% Render at: https://mermaid.live/ or integrate into markdown viewer

%% ── Agent Topology ──
graph TB
    subgraph Presentation["Presentation Layer"]
        D1["C-Level Dashboards"]
        D2["Operations UI"]
        D3["Finance Console"]
        D4["Supply Chain Hub"]
    end

    subgraph Orchestration["Orchestrator & Governance Layer"]
        O09["Agent-09: Orchestrator & Governance"]
        O09_1["- Cross-agent arbitration"]
        O09_2["- HITL escalation"]
        O09_3["- KPI dashboards"]
        O09_4["- Model version control"]
        O09_5["- Rollback coordination"]
    end

    subgraph Intelligence["Intelligence & Optimization Layer"]
        A05["Agent-05: Market Intelligence"]
        A06["Agent-06: Predictive Analytics & Demand Planning"]
        A08["Agent-08: Compliance & Risk"]
        A07["Agent-07: Financial & Cost Accounting"]
    end

    subgraph Execution["Execution & Operations Layer"]
        A01["Agent-01: Procurement"]
        A02["Agent-02: Production & MES"]
        A03["Agent-03: Inventory & Warehousing"]
        A04["Agent-04: Sales & Distribution"]
    end

    subgraph DataLayer["Data & Integration Layer"]
        Kafka["Kafka / Pulsar<br>Event Streaming"]
        Delta["Delta Lake / Iceberg<br>Data Lakehouse"]
        PG["PostgreSQL<br>Relational Data"]
        Redis["Redis<br>Cache & Feature Store"]
        MinIO["MinIO<br>Object Store / WORM Audit"]
        DQ["Data Quality Gates<br>Great Expectations / Deequ"]
    end

    subgraph Sources["External Systems & Data Sources"]
        ERP("ERP<br>SAP / Oracle")
        MES("MES<br>Siemens / Rockwell")
        SCM("SCM")
        CRM("CRM<br>Salesforce")
        IoT("IoT / Sensors")
        POS("POS / Retailer<br>EDI Feeds")
        Banking("Banking /<br>Payment APIs")
        Market("Market Data<br>Bloomberg / LME")
        Social("Social / Web<br>Scraping")
    end

    %% Presentation connections
    D1 --> O09
    D2 --> O09
    D3 --> O07
    D4 --> O01

    %% Orchestrator to Intelligence
    O09 --> A05
    O09 --> A06
    O09 --> A08
    O09 --> A07

    %% Orchestrator to Execution
    O09 --> A01
    O09 --> A02
    O09 --> A03
    O09 --> A04

    %% Intelligence to Data
    A05 --> Kafka
    A06 --> Delta
    A07 --> PG
    A08 --> MinIO

    %% Execution to Data
    A01 --> Kafka
    A02 --> Delta
    A03 --> Redis
    A04 --> PG

    %% Data to Sources
    Kafka --> ERP
    Delta --> MES
    PG --> SCM
    Redis --> CRM
    DQ --> IoT
    DQ --> POS
    DQ --> Banking
    DQ --> Market
    DQ --> Social

    %% Cross-agent Intelligence communication
    A05 -.-> A06
    A06 -.-> A07

    %% Cross-agent Execution communication
    A01 -.-> A02
    A02 -.-> A03
    A03 -.-> A04
    A04 -.-> A01

    %% Data quality layer
    Delta --> DQ
    Kafka --> DQ
    DQ --> PG

